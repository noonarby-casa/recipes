{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "*": [
        "../themes/cookpot/assets/*"
      ]
    }
  },
  "include": [
    "../themes/cookpot/assets/js/**/*"
  ]
}
